{
  "name": "spectre-debug",
  "displayName": "S.P.E.C.T.R.E",
  "description": "System for Proactive Engineering and Code Technical Real-time Evaluation",
  "version": "1.0.0",
  "publisher": "spectre-ai",
  "icon": "media/logo.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Machine Learning",
    "Education"
  ],
  "keywords": [
    "AI",
    "Debug",
    "Gemini",
    "Spectre",
    "Code Review"
  ],
  "homepage": "https://fir-p-e-c-t-r-e-bdd37.web.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxprime558/spectre"
  },
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "spectre.openPanel",
        "title": "S.P.E.C.T.R.E: Open Analysis Panel",
        "icon": "$(terminal)"
      }
    ],
    "configuration": {
      "title": "S.P.E.C.T.R.E",
      "properties": {
        "spectre.backendUrl": {
          "type": "string",
          "default": "https://fir-p-e-c-t-r-e-bdd37.web.app/",
          "description": "URL of the SPECTRE web application."
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "eslint": "^8.33.0"
  }
}
