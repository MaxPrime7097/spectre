rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: timeline
    // Document ID: {eventId}
    // Fields:
    //   - time: string (ISO 8601) - required
    //   - issue: string - required
    //   - userId: string - required (must match auth.uid)
    //   - data: map (SpectreAnalysis) - optional
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "maxprime558@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidTimelineEvent(data) {
      return data.keys().hasAll(['time', 'issue', 'userId']) &&
             data.time is string &&
             data.issue is string &&
             data.userId is string &&
             data.userId == request.auth.uid;
    }

    // Rules
    match /timeline/{eventId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidTimelineEvent(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidTimelineEvent(request.resource.data) && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
